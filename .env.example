[required]
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY_PATH=./your-app.pem

[optional]
GITHUB_TOKEN=
GITHUB_APP_INSTALLATION_ID=
GITHUB_REPO=owner/repo                # only needed in polling mode; leave blank for webhook-only
WEBHOOK_SECRET=                       # required for webhook mode — generate with: openssl rand -hex 32
WEBHOOK_PORT=8090
STATS_URL=                            # POST here after each review (leave empty to disable)
AUTO_APPROVE=false                    # enforce review gating — APPROVE/REQUEST_CHANGES/COMMENT by verdict; off = always COMMENT

[defaults — no need to change]
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local             # use exact model ID from GET /v1/models if "local" returns 400 (e.g. liquid/lfm2.5-1.2b)
LM_STUDIO_MAX_TOKENS=4096
POLL_INTERVAL=300
SKIP_DRAFT_PRS=true
RECHECK_UPDATED_PRS=true
MAX_DIFF_CHARS=400000
MAX_FILES_IN_DIFF=100
MAX_LINES_PER_FILE=2000
IGNORE_FILE_PATTERNS=*.lock,package-lock.json,*.min.js,*.min.css,dist/*,build/*
