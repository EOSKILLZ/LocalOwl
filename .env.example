# LocalOwl Configuration
# Copy this file to .env and fill in your values

# ── LM Studio ────────────────────────────────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local
LM_STUDIO_MAX_TOKENS=2000

# ── GitHub App (recommended) ──────────────────────────────────────────────────
# Create a GitHub App at github.com/settings/apps
# Set Pull Requests: Read & Write, then install it on your repos
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY_PATH=./your-app.pem
# GITHUB_APP_INSTALLATION_ID=  # optional — auto-detected

# ── GitHub Personal Token (fallback) ─────────────────────────────────────────
# Only needed if you're not using a GitHub App
# GITHUB_TOKEN=ghp_...

# ── Repos to monitor ─────────────────────────────────────────────────────────
# Single:   owner/repo
# Multiple: owner/repo1,owner/repo2
GITHUB_REPO=owner/repo

# ── Mode: polling (default) or webhook ───────────────────────────────────────
# Polling is recommended for self-hosted setups — no open ports required.
# To use webhooks instead, set WEBHOOK_SECRET and point your GitHub App's
# webhook URL to http://your-server:8090/webhook
POLL_INTERVAL=300
SKIP_DRAFT_PRS=true
RECHECK_UPDATED_PRS=true

# WEBHOOK_SECRET=your_webhook_secret_here
# WEBHOOK_PORT=8090

# ── Diff limits ───────────────────────────────────────────────────────────────
MAX_DIFF_CHARS=30000
MAX_FILES_IN_DIFF=20
MAX_LINES_PER_FILE=300

# ── Ignore patterns (comma-separated globs) ───────────────────────────────────
# IGNORE_FILE_PATTERNS=*.lock,package-lock.json,*.min.js,*.min.css,dist/*,build/*
